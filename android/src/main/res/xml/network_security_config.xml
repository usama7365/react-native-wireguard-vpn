<?xml version="1.0" encoding="utf-8"?>
<!-- Required by AndroidManifest.xml android:networkSecurityConfig. Prevents EAS/build "resource not found" (issue #5). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
